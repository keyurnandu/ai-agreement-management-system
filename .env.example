# =====================================================================
# contract-platform — central configuration
#
# Copy to .env and adjust. EVERY external dependency is behind an
# adapter selected here, so switching from local to cloud is a config
# change, not a code change.
# =====================================================================

# ── Core ─────────────────────────────────────────────────────────────
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# ── Service URLs (web gateway calls these) ───────────────────────────
PDF_ENGINE_URL=http://localhost:8001
INTELLIGENCE_URL=http://localhost:8002

# ── Database — web owns all persistence (Prisma) ─────────────────────
# local SQLite (zero-setup). NOTE: Prisma resolves a SQLite path relative
# to the schema dir (apps/web/prisma), so this lands at apps/web/prisma/dev.db.
#   cloud: postgresql://user:pass@host:5432/contract
# (when moving to Postgres, also set datasource provider in schema.prisma)
DATABASE_URL=file:./dev.db

# ── Storage adapter ──────────────────────────────────────────────────
# local | s3
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=./data/files
# Used when STORAGE_PROVIDER=s3 (also works with S3-compatible MinIO):
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Auth adapter ─────────────────────────────────────────────────────
# credentials | oidc
AUTH_PROVIDER=credentials
# Generate with:  openssl rand -base64 32   (or: npx auth secret)
AUTH_SECRET=dev-only-change-me-please-32-chars-min
# Used when AUTH_PROVIDER=oidc (Okta / Entra / Auth0 / etc.):
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ── Service-to-service auth (web signs short-lived JWT) ──────────────
SERVICE_JWT_SECRET=dev-shared-service-secret-change-me

# ── AI provider (intelligence service) ───────────────────────────────
# mock | ollama | anthropic | openai
#   mock   = deterministic stub, runs with ZERO keys (default)
#   ollama = fully local LLM (requires Ollama running)
AI_PROVIDER=mock
AI_MODEL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── Vector store (intelligence service, for RAG) ─────────────────────
# local | pgvector | pinecone
VECTOR_STORE=local
VECTOR_STORE_PATH=./data/vectors
EMBEDDING_PROVIDER=mock
